# Server
PORT=5000
NODE_ENV=development

# MongoDB (MERN Stack)
# If set, uses MongoDB. If empty, falls back to JSON file DB for easy local dev.
MONGO_URI=mongodb://localhost:27017/carbonlink
# Or use MongoDB Atlas:
# MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/carbonlink?retryWrites=true&w=majority

# JWT
JWT_SECRET=your_super_secret_jwt_key_here
JWT_EXPIRES_IN=7d

# Google OAuth (optional — get from console.cloud.google.com)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# Client
CLIENT_URL=http://localhost:5173
